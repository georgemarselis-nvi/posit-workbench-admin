# site-local config: ~/.bashrc.d/rstudio_server.conf
# required variables:
#   RSTUDIO_SERVER_BIN  — full path to rstudio-server binary e.g. /usr/sbin/rstudio-server
#   LDAP_HOST           — LDAP URI e.g. ldap://dc02.example.com:3268
#   LDAP_BASE           — LDAP search base e.g. dc=example,dc=com
#   LDAP_DOMAIN         — domain suffix for userPrincipalName e.g. example.com
[[ -f "${HOME}/.bashrc.d/rstudio_server.conf" ]] && source "${HOME}/.bashrc.d/rstudio_server.conf" || { echo "rstudio_server: missing ~/.bashrc.d/rstudio_server.conf" >&2 ; return 1 ; }


# list active RStudio sessions with display names resolved via LDAP
# output: username, display_name, sessionId, type, startTime, days, hours, minutes
# example: rstudio_active_sessions

rstudio_active_sessions() {
    if ! /usr/bin/klist -s ; then
        echo "No valid Kerberos ticket found. Please enter your password."
        read -s -p "Enter password: " password ; echo
        echo "${password}" | /usr/bin/kinit
        if [[ $? -ne 0 ]] ; then echo "${FUNCNAME[0]}: Kerberos authentication failed." >&2 ; return 1 ; fi
    fi

    local sessions ; sessions="$( "${RSTUDIO_SERVER_BIN}" active-sessions 2>/dev/null | /usr/bin/grep -v '^Active sessions result:' | /usr/bin/jq -r '.' 2>/dev/null )"
    [[ -z "${sessions}" ]] && { echo "${FUNCNAME[0]}: no output from rstudio-server" >&2 ; return 1 ; }

    local ldap_json ; ldap_json="$( /usr/bin/jq -r '.sessions[].username' <<< "${sessions}" | while IFS= read -r uname ; do dn="$( /usr/bin/ldapsearch -LLL -Q -H "${LDAP_HOST}" -Y GSSAPI -b "${LDAP_BASE}" "(&(objectClass=user)(userPrincipalName=${uname}))" displayName 2>/dev/null | /usr/bin/grep '^displayName:' | /usr/bin/awk '{$1=""; print $0}' | /usr/bin/sed 's/^ //' )" ; /usr/bin/jq -n --arg u "${uname}" --arg d "${dn:-N/A}" '{"username":$u,"display_name":$d}' ; done | /usr/bin/jq -s '.' )"

    /usr/bin/jq -c --argjson ldap "${ldap_json}" '[.sessions[] | . as $s | ($ldap[] | select(.username == $s.username) | .display_name) as $dn | (([0, (now - ($s.startTime | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime))] | max)) as $sec | {"username":$s.username,"display_name":$dn,"sessionId":$s.sessionId,"type":$s.type,"startTime":($s.startTime | strptime("%Y-%m-%dT%H:%M:%SZ") | strftime("%Y-%m-%d")),"days":($sec/86400|floor),"hours":(($sec%86400/3600)|floor),"minutes":(($sec%3600/60)|floor)}][]' <<< "${sessions}" | /usr/bin/mlr --ijson --opprint cat
}


# wrapper for rstudio-server
# intercepts kill-session, suspend-session, force-suspend-session, force-suspend
# and strips username_displayName:sessionId tokens down to bare sessionId
# all other subcommands pass through unchanged
# example: rstudio-server kill-session vi1570_Kausrud,_Kyrre:17cfecfc78a31a8d2ac2c

rstudio-server() {
    case "${1}" in
        kill-session|suspend-session|force-suspend-session|force-suspend)
            local sid ; sid="${2##*:}"
            "${RSTUDIO_SERVER_BIN}" "${1}" "${sid}"
            ;;
        *)
            "${RSTUDIO_SERVER_BIN}" "$@"
            ;;
    esac
}


# bash completion for rstudio-server
_rstudio_server_complete() {
    local cur prev
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    COMP_WORDBREAKS="${COMP_WORDBREAKS//:}"

    local subcommands="status start stop restart reload offline online version vs-code-version positron-version test-config verify-installation run-diagnostics upload-minidump active-sessions suspend-session suspend-all force-suspend-session force-suspend kill-session kill-all configure-vs-code install-vs-code-ext install-positron-ext list-users add-user set-admin lock-user unlock-user user-service list-nodes node-status delete-node reset-cluster generate-api-token list-api-tokens revoke-api-token"

    if [[ "${COMP_CWORD}" -eq 1 ]] ; then
        COMPREPLY=( $( compgen -W "${subcommands}" -- "${cur}" ) )
        return 0
    fi

    case "${prev}" in
        kill-session|suspend-session|force-suspend-session|force-suspend)
            # NOTE: suspend-session, force-suspend-session, force-suspend likely non-functional
            local _sessions ; _sessions="$( "${RSTUDIO_SERVER_BIN}" active-sessions 2>/dev/null | /usr/bin/grep -v '^Active sessions result:' | /usr/bin/jq -r '.' 2>/dev/null )"
            local tokens ; tokens="$( /usr/bin/jq -r '.sessions[].username' <<< "${_sessions}" | while IFS= read -r uname ; do dn="$( /usr/bin/ldapsearch -LLL -Q -H "${LDAP_HOST}" -Y GSSAPI -b "${LDAP_BASE}" '(&(objectClass=user)(userPrincipalName='"${uname}"'))' displayName 2>/dev/null | /usr/bin/grep '^displayName:' | /usr/bin/awk '{$1=""; print $0}' | /usr/bin/sed 's/^ //' )" ; sid="$( /usr/bin/jq -r --arg u "${uname}" '.sessions[] | select(.username==$u) | .sessionId' <<< "${_sessions}" )" ; echo "${uname}_${dn// /_}:${sid}" ; done )"
            COMPREPLY=( $( compgen -W "${tokens}" -- "${cur}" ) )
            ;;
        add-user|set-admin|lock-user|unlock-user|user-service|revoke-api-token)
            COMPREPLY=( $( compgen -W "$( "${RSTUDIO_SERVER_BIN}" list-users 2>/dev/null | /usr/bin/awk 'NR>1 {print $1}' )" -- "${cur}" ) )
            ;;
        *)
            COMPREPLY=()
            ;;
    esac
}

complete -F _rstudio_server_complete rstudio-server
complete -F _rstudio_server_complete "${RSTUDIO_SERVER_BIN}"
