# rstudio_server
# wrapper functions and bash completion for /usr/sbin/rstudio-server
# requires: /usr/bin/jq, /usr/bin/mlr, /usr/bin/ldapsearch (openldap-clients)
# reads site-local config from ~/.bashrc.d/rstudio_server.conf
# must run as root or a user with sudo access to rstudio-server
#
# site-local config: ~/.bashrc.d/rstudio_server.conf
# required variables:
#   RSTUDIO_SERVER_BIN  — full path to rstudio-server binary e.g. /usr/sbin/rstudio-server
#   LDAP_HOST           — LDAP URI e.g. ldap://dc02.example.com:3268
#   LDAP_BASE           — LDAP search base e.g. dc=example,dc=com
#   LDAP_DOMAIN         — domain suffix for userPrincipalName e.g. example.com
#
# example:  rstudio_active_sessions
#           rstudio-server kill-session <TAB>
#           rstudio-server lock-user <TAB>
#
# NOTE: the following subcommands are confirmed non-functional on this installation:
#   suspend-session, suspend-all, force-suspend-session, force-suspend
#   list-nodes, node-status, delete-node, reset-cluster  (load balancing disabled)
#   configure-vs-code, install-vs-code-ext
